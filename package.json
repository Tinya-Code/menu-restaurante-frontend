{
  "name": "menu-restaurante-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "bun run config -- --environment=dev && ng serve --configuration development",
    "start": "ng serve",
    "config": "node ./config/set-env.config.js",
    "build": "bun run config -- --environment=prod && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@tailwindcss/postcss": "^4.2.2",
    "dotenv": "^17.2.3",
    "firebase": "^12.8.0",
    "leaflet": "^1.9.4",
    "lucide-angular": "^1.0.0",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@types/jasmine": "~5.1.0",
    "@types/leaflet": "^1.9.21",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.3",
    "typescript": "~5.9.2"
  }
}